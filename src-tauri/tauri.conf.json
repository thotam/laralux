{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Laragon Linux",
  "version": "0.1.0",
  "identifier": "com.laragon.linux",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Laragon Linux",
        "width": 900,
        "height": 600,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/icon.png"]
  }
}
