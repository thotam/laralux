{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Laralux",
  "version": "0.1.0",
  "identifier": "com.laralux.linux",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Laralux",
        "width": 900,
        "height": 820,
        "minWidth": 720,
        "minHeight": 520,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/icon.png"]
  }
}
